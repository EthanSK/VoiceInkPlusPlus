    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceInk muss mit Ihrem Browser interagieren, um den Website-Kontext zu erkennen, und mit Terminal oder iTerm, um Transkriptionstext und, wenn konfiguriert, die Eingabetaste an die exakt gespeicherte Terminalsitzung zu senden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "VoiceInk needs to interact with your browser to detect website context and with Terminal or iTerm to send transcription text and, when configured, Return to the exact saved terminal session."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "VoiceInk 需要与浏览器交互以检测网站上下文，并与终端或 iTerm 交互以将转写文本以及（如已配置）回车发送到准确保存的终端会话。"
          }
        }
      }
    },
    "NSHumanReadableCopyright" : {
      "comment" : "Copyright (human-readable)",
      "extractionState" : "extracted_with_value",
      "localizations" : {
